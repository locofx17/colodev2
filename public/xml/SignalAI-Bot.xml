<xml xmlns="https://developers.google.com/blockly/xml" is_dbot="true" collection="false">
  <variables>
    <variable id="sai_stake_id">Stake</variable>
    <variable id="sai_tp_id">Take Profit</variable>
    <variable id="sai_sl_id">Stop Loss</variable>
    <variable id="sai_entry_point_id">entry_point</variable>
    <variable id="sai_martingale_id">Martingale</variable>
    <variable id="sai_winstake_id">win-stake</variable>
    <variable id="sai_entry_loop_id">entry_loop</variable>
  </variables>
  <block type="trade_definition" id="sai_trade_def" deletable="false" x="0" y="110">
    <statement name="TRADE_OPTIONS">
      <block type="trade_definition_market" id="sai_market" deletable="false" movable="false">
        <field name="MARKET_LIST">synthetic_index</field>
        <field name="SUBMARKET_LIST">random_index</field>
        <field name="SYMBOL_LIST">1HZ25V</field>
        <field name="VIRTUAL_HOOK">FALSE</field>
        <field name="ALTERNATING_MARKET">FALSE</field>
        <field name="SCANNING_ALL_MARKET">FALSE</field>
        <next>
          <block type="trade_definition_tradetype" id="sai_tradetype" deletable="false" movable="false">
            <field name="TRADETYPECAT_LIST">callput</field>
            <field name="TRADETYPE_LIST">callput</field>
            <next>
              <block type="trade_definition_contracttype" id="sai_contracttype" deletable="false" movable="false">
                <field name="TYPE_LIST">put</field>
                <next>
                  <block type="trade_definition_candleinterval" id="sai_candle" deletable="false" movable="false">
                    <field name="CANDLEINTERVAL_LIST">60</field>
                    <next>
                      <block type="trade_definition_restartbuysell" id="sai_restart_buysell" deletable="false" movable="false">
                        <field name="TIME_MACHINE_ENABLED">FALSE</field>
                        <next>
                          <block type="trade_definition_restartonerror" id="sai_restart_error" deletable="false" movable="false">
                            <field name="RESTARTONERROR">TRUE</field>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
    <statement name="INITIALIZATION">
      <block type="variables_set" id="sai_init_stake">
        <field name="VAR" id="sai_stake_id">Stake</field>
        <value name="VALUE">
          <block type="math_number" id="sai_stake_val">
            <field name="NUM">5</field>
          </block>
        </value>
        <next>
          <block type="variables_set" id="sai_init_tp">
            <field name="VAR" id="sai_tp_id">Take Profit</field>
            <value name="VALUE">
              <block type="math_number" id="sai_tp_val">
                <field name="NUM">100</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="sai_init_sl">
                <field name="VAR" id="sai_sl_id">Stop Loss</field>
                <value name="VALUE">
                  <block type="math_number" id="sai_sl_val">
                    <field name="NUM">100</field>
                  </block>
                </value>
                <next>
                  <block type="variables_set" id="sai_init_entry">
                    <field name="VAR" id="sai_entry_point_id">entry_point</field>
                    <value name="VALUE">
                      <block type="math_number" id="sai_entry_val">
                        <field name="NUM">3</field>
                      </block>
                    </value>
                    <next>
                      <block type="variables_set" id="sai_init_martingale">
                        <field name="VAR" id="sai_martingale_id">Martingale</field>
                        <value name="VALUE">
                          <block type="math_number" id="sai_martingale_val">
                            <field name="NUM">2</field>
                          </block>
                        </value>
                        <next>
                          <block type="variables_set" id="sai_init_winstake">
                            <field name="VAR" id="sai_winstake_id">win-stake</field>
                            <value name="VALUE">
                              <block type="variables_get" id="sai_get_stake_winstake">
                                <field name="VAR" id="sai_stake_id">Stake</field>
                              </block>
                            </value>
                            <next>
                              <block type="variables_set" id="sai_init_loop">
                                <field name="VAR" id="sai_entry_loop_id">entry_loop</field>
                                <value name="VALUE">
                                  <block type="logic_boolean" id="sai_loop_true">
                                    <field name="BOOL">TRUE</field>
                                  </block>
                                </value>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
    <statement name="SUBMARKET">
      <block type="controls_whileUntil" id="sai_while_loop">
        <field name="MODE">UNTIL</field>
        <value name="BOOL">
          <block type="logic_compare" id="sai_loop_compare">
            <field name="OP">EQ</field>
            <value name="A">
              <block type="variables_get" id="sai_get_entry_loop">
                <field name="VAR" id="sai_entry_loop_id">entry_loop</field>
              </block>
            </value>
            <value name="B">
              <block type="logic_boolean" id="sai_loop_false_cond">
                <field name="BOOL">FALSE</field>
              </block>
            </value>
          </block>
        </value>
        <statement name="DO">
          <block type="controls_repeat_inf" id="sai_repeat_inf">
            <statement name="DO">
              <block type="notify" id="sai_notify_green">
                <field name="NOTIFICATION_TYPE">success</field>
                <field name="NOTIFICATION_SOUND">silent</field>
                <value name="MESSAGE">
                  <shadow type="text" id="sai_notify_text">
                    <field name="TEXT">Last Digit</field>
                  </shadow>
                </value>
                <next>
                  <block type="controls_if" id="sai_check_entry">
                    <value name="IF0">
                      <block type="logic_compare" id="sai_entry_cmp">
                        <field name="OP">EQ</field>
                        <value name="A">
                          <block type="variables_get" id="sai_get_entry_point">
                            <field name="VAR" id="sai_entry_point_id">entry_point</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="last_digit" id="sai_last_digit_check">
                          </block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO0">
                      <block type="controls_flow_statements" id="sai_break_loop">
                        <field name="FLOW">BREAK</field>
                      </block>
                    </statement>
                  </block>
                </next>
              </block>
            </statement>
          </block>
        </statement>
        <next>
          <block type="timeout" id="sai_timeout">
            <statement name="TIMEOUTSTACK">
              <block type="trade_definition_tradeoptions" id="sai_trade_options">
                <mutation xmlns="http://www.w3.org/1999/xhtml" has_first_barrier="false" has_second_barrier="false" has_prediction="false"></mutation>
                <field name="DURATIONTYPE_LIST">t</field>
                <field name="TURBO_MODE">FALSE</field>
                <value name="DURATION">
                  <shadow type="math_number_positive" id="sai_duration_val">
                    <field name="NUM">1</field>
                  </shadow>
                </value>
                <value name="AMOUNT">
                  <block type="variables_get" id="sai_get_stake_options">
                    <field name="VAR" id="sai_stake_id">Stake</field>
                  </block>
                </value>
              </block>
            </statement>
            <value name="SECONDS">
              <block type="math_number" id="sai_timeout_seconds">
                <field name="NUM">0</field>
              </block>
            </value>
          </block>
        </next>
      </block>
    </statement>
  </block>
  <block type="after_purchase" id="sai_after_purchase" x="714" y="336">
    <statement name="AFTERPURCHASE_STACK">
      <block type="variables_set" id="sai_reset_entry_loop">
        <field name="VAR" id="sai_entry_loop_id">entry_loop</field>
        <value name="VALUE">
          <block type="logic_boolean" id="sai_reset_loop_false">
            <field name="BOOL">FALSE</field>
          </block>
        </value>
        <next>
          <block type="controls_if" id="sai_tp_sl_check">
            <mutation xmlns="http://www.w3.org/1999/xhtml" elseif="1" else="1"></mutation>
            <value name="IF0">
              <block type="logic_compare" id="sai_tp_compare">
                <field name="OP">GTE</field>
                <value name="A">
                  <block type="total_profit" id="sai_total_profit_tp"></block>
                </value>
                <value name="B">
                  <block type="variables_get" id="sai_get_tp">
                    <field name="VAR" id="sai_tp_id">Take Profit</field>
                  </block>
                </value>
              </block>
            </value>
            <statement name="DO0">
              <block type="text_print" id="sai_print_tp">
                <value name="TEXT">
                  <shadow type="text" id="sai_tp_text">
                    <field name="TEXT">TP hit</field>
                  </shadow>
                </value>
              </block>
            </statement>
            <value name="IF1">
              <block type="logic_compare" id="sai_sl_compare">
                <field name="OP">LTE</field>
                <value name="A">
                  <block type="total_profit" id="sai_total_profit_sl"></block>
                </value>
                <value name="B">
                  <block type="math_single" id="sai_neg_sl">
                    <field name="OP">NEG</field>
                    <value name="NUM">
                      <block type="variables_get" id="sai_get_sl">
                        <field name="VAR" id="sai_sl_id">Stop Loss</field>
                      </block>
                    </value>
                  </block>
                </value>
              </block>
            </value>
            <statement name="DO1">
              <block type="text_print" id="sai_print_sl">
                <value name="TEXT">
                  <shadow type="text" id="sai_sl_text">
                    <field name="TEXT">SL hit</field>
                  </shadow>
                </value>
              </block>
            </statement>
            <statement name="ELSE">
              <block type="controls_if" id="sai_win_loss_check">
                <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
                <value name="IF0">
                  <block type="contract_check_result" id="sai_check_win">
                    <field name="CHECK_RESULT">win</field>
                  </block>
                </value>
                <statement name="DO0">
                  <block type="variables_set" id="sai_win_set_stake">
                    <field name="VAR" id="sai_stake_id">Stake</field>
                    <value name="VALUE">
                      <block type="variables_get" id="sai_win_get_winstake">
                        <field name="VAR" id="sai_winstake_id">win-stake</field>
                      </block>
                    </value>
                    <next>
                      <block type="trade_again" id="sai_trade_again_win"></block>
                    </next>
                  </block>
                </statement>
                <statement name="ELSE">
                  <block type="variables_set" id="sai_loss_set_stake">
                    <field name="VAR" id="sai_stake_id">Stake</field>
                    <value name="VALUE">
                      <block type="math_arithmetic" id="sai_martingale_calc">
                        <field name="OP">MULTIPLY</field>
                        <value name="A">
                          <block type="variables_get" id="sai_loss_get_stake">
                            <field name="VAR" id="sai_stake_id">Stake</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="variables_get" id="sai_loss_get_martingale">
                            <field name="VAR" id="sai_martingale_id">Martingale</field>
                          </block>
                        </value>
                      </block>
                    </value>
                    <next>
                      <block type="trade_again" id="sai_trade_again_loss"></block>
                    </next>
                  </block>
                </statement>
              </block>
            </statement>
          </block>
        </next>
      </block>
    </statement>
  </block>
  <block type="before_purchase" id="sai_before_purchase" deletable="false" x="0" y="1128">
    <statement name="BEFOREPURCHASE_STACK">
      <block type="purchase" id="sai_purchase">
        <field name="PURCHASE_LIST">PUT</field>
      </block>
    </statement>
  </block>
</xml>
